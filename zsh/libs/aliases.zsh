alias nf="neofetch"
alias of="onefetch"

alias nv="nvim"
alias vs="codium --user-data-dir ${XDG_STATE_HOME}/vscodium --extensions-dir ${XDG_STATE_HOME}/vscodium/extensions"

alias l='ls -lahG'
alias ll='ls -lhG'
alias ls='ls -G'

alias -- -='cd -'
alias -g ..='cd ../'
alias -g ...='cd ../..'
alias -g ....='cd ../../..'
alias -g .....='cd ../../../..'
alias -g ......='cd ../../../../..'

alias md='mkdir -p'
alias rd='rmdir'

alias grep='ggrep --color=auto'
alias egrep='egrep --color=auto'
alias fgrep='fgrep --color=auto'

alias so="source"
alias cl="clear"
alias oo="open ./"
alias coffee="caffeinate -disu"

alias tm="tmux new-session -A -s home"
alias ghci="ghci -fno-ghci-history"
